# ============================================================================
# Batuta · variáveis de ambiente (copie para .env e preencha)
# ============================================================================

# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8787                      # porta do servidor MCP

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=    # service role (somente backend, NUNCA no cliente)
DATABASE_URL=                 # string psql, usada por `pnpm db:push`

# Chave de cifragem dos tokens OAuth guardados em `connections`
BATUTA_ENCRYPTION_KEY=        # 32+ bytes aleatórios

# ── Google Ads ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID= # MCC, se a conta estiver sob um gerenciador

# ── Meta Ads ────────────────────────────────────────────────────────────────
META_CLIENT_ID=
META_CLIENT_SECRET=

# ── TikTok Ads ──────────────────────────────────────────────────────────────
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# ── LinkedIn Ads ────────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Asaas (cobrança Pix/cartão) ─────────────────────────────────────────────
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=          # token que valida o webhook em /api/asaas/webhook

# ── WhatsApp (agente proativo) ──────────────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── Dev only ────────────────────────────────────────────────────────────────
DEV_PLATFORM_TOKEN=dev-token  # token fake de plataforma pra rodar local
